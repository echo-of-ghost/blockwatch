{
  "name": "blockwatch",
  "version": "2.2.3",
  "description": "Real-time Bitcoin node dashboard",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "start:testnet4": "BITCOIN_RPC_PORT=48332 node server.js",
    "start:signet": "BITCOIN_RPC_PORT=38332 node server.js",
    "start:regtest": "BITCOIN_RPC_PORT=18443 node server.js",
    "app": "electron .",
    "dist": "electron-builder --linux",
    "release": "npm run dist && gpg --detach-sign --armor dist/*.AppImage"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "zeromq": "^6.5.0"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.blockwatch.dashboard",
    "productName": "Blockwatch",
    "icon": "assets/icon.png",
    "files": [
      "server.js",
      "index.html",
      "blockwatch.css",
      "robots.txt",
      "*.woff2",
      "assets/**",
      "client/**",
      "electron/**",
      "node_modules/**"
    ],
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "category": "Finance"
    }
  },
  "author": "Maple <maplehodl@protonmail.com>",
  "license": "GPL-3.0"
}
